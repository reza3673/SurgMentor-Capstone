# .gitignore — SurgMentor Competition Project
# For future use when repository is published manually.

# ── Secrets ───────────────────────────────────────────────────────────────────
.env

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual environments ──────────────────────────────────────────────────────
venv/
.venv/
env/
ENV/

# ── Data (generated at runtime) ───────────────────────────────────────────────
data/prepared_cases.json
data/*.db
data/surgmentor_agent.db

# ── Vector database ───────────────────────────────────────────────────────────
# The pre-built ChromaDB (chroma.sqlite3 + segment dirs) is INCLUDED in the
# repository for judge convenience — no Jina API key or rebuild step required.
# Only test artifacts produced by the test suite are excluded.
db/test.sqlite3
db/test.sqlite3-journal
db/write_test.txt

# ── Evaluation logs (generated at runtime) ────────────────────────────────────
eval_log.jsonl

# ── IDE ───────────────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
.DS_Store
Thumbs.db

# ── Testing ───────────────────────────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── Temporary ─────────────────────────────────────────────────────────────────
temp/
tmp/
*.log

# ── Internal planning documents (archived, not for public repo) ───────────────
docs/PHASE_*.md
docs/GAP_ANALYSIS.md
docs/MIGRATION_PLAN.md
docs/TARGET_ARCHITECTURE.md
docs/PROJECT_UNDERSTANDING.md
docs/IMPLEMENTATION_SEQUENCE_REVIEW.md
docs/CUSTOM_FRONTEND_PLAN.md
docs/FRONTEND_REDESIGN_PLAN.md
docs/ARCHITECTURE_IMAGE_SPEC.md
docs/COVER_IMAGE_SPEC.md
project_docs/
