# .env.example
# SurgMentor environment variables
#
# Copy this file to .env and fill in real values:
#   cp .env.example .env
#
# NEVER commit .env to version control.
# This file (.env.example) is safe to commit — it contains no real secrets.

# ── Required: LLM ─────────────────────────────────────────────────────────────
DEEPSEEK_API_KEY=your-deepseek-api-key-here

# ── Required: Embeddings ──────────────────────────────────────────────────────
JINA_API_KEY=your-jina-api-key-here

# ── Optional: Storage ─────────────────────────────────────────────────────────
# Path to the SQLite database for student profiles and OSCE results.
# Defaults to ./data/surgmentor_agent.db if not set.
AGENT_SESSION_DB_PATH=./data/surgmentor_agent.db

# Path to the ChromaDB vector store directory.
# Defaults to ./db if not set.
CHROMA_DB_PATH=./db

# ── Optional: Interface ───────────────────────────────────────────────────────
# Port for the Gradio web UI (fallback). Defaults to 7860.
GRADIO_PORT=7860

# Port for the FastAPI custom frontend server. Defaults to 8000.
FASTAPI_PORT=8000

# Enable LLM-based scope classification in the Security Layer.
# Set to false to skip the LLM scope check (faster, no API call, for testing).
# Defaults to true.
SCOPE_CLASSIFICATION_ENABLED=true

# ── Optional: MCP Server (stretch goal) ───────────────────────────────────────
# Set to true to enable the MCP server alongside the agent controller.
# Requires the mcp package to be installed (see requirements.txt).
USE_MCP=false
MCP_SERVER_PORT=8765
